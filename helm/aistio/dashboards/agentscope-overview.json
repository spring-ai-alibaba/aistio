{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Agent Overview",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "name", "desc": false }]
      },
      "targets": [
        {
          "expr": "agentscope_agent_info",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "agentscope_agent_replicas{kind=\"desired\"}",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "agentscope_agent_replicas{kind=\"ready\"}",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "agentscope_sessions_active",
          "format": "table",
          "instant": true,
          "refId": "D"
        },
        {
          "expr": "agentscope_dataplane_connected",
          "format": "table",
          "instant": true,
          "refId": "E"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "info",
              "Value #B": "desired",
              "Value #C": "ready",
              "Value #D": "sessions",
              "Value #E": "connected"
            }
          }
        }
      ]
    },
    {
      "title": "Active Sessions by Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "agentscope_sessions_active",
          "legendFormat": "{{ namespace }}/{{ agent }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Data Plane Connection Status",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "Disconnected", "color": "red" }, "1": { "text": "Connected", "color": "green" } }, "type": "value" }
          ],
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "expr": "agentscope_dataplane_connected",
          "legendFormat": "{{ namespace }}/{{ name }}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "title": "Session Operations",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" },
        "xTickLabelRotation": 0,
        "stacking": "normal"
      },
      "targets": [
        {
          "expr": "increase(agentscope_session_operations_total[1h])",
          "legendFormat": "{{ operation }}/{{ result }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Probe Latency",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": { "scheme": "Oranges" },
        "tooltip": { "show": true }
      },
      "targets": [
        {
          "expr": "increase(agentscope_probe_duration_seconds_bucket[5m])",
          "legendFormat": "{{ le }}",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Reconcile Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(controller_runtime_reconcile_total[5m])",
          "legendFormat": "{{ controller }}/{{ result }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Reconcile Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(agentscope_reconcile_errors_total[5m])",
          "legendFormat": "{{ controller }}/{{ reason }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Teams",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "expr": "agentscope_teams_active",
          "legendFormat": "Active Teams",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "title": "Team Members by Phase",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "agentscope_team_members_by_phase",
          "legendFormat": "{{ team }} - {{ phase }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Team Tasks by State",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "agentscope_team_tasks_by_state",
          "legendFormat": "{{ team }} - {{ state }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Team Messages",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(agentscope_team_messages_total[5m])",
          "legendFormat": "{{ team }} - {{ status }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Team Recovery Attempts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(agentscope_team_recovery_total[5m])",
          "legendFormat": "{{ team }} - {{ result }}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["agentscope", "kubernetes"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data Source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AgentScope Overview",
  "uid": "agentscope-overview",
  "version": 1
}
